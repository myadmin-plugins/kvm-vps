{
	"name": "detain/myadmin-kvm-vps",
	"type": "myadmin-plugin",
	"description": "MyAdmin KVM VPS plugin — provides service activation, deactivation, queue processing, and settings management for KVM-based virtual private servers.",
	"keywords": [
		"kvm",
		"vps",
		"virtualization",
		"myadmin",
		"plugin",
		"administration"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https:\/\/my.interserver.net\/"
		}
	],
	"config": {
		"bin-dir": "vendor\/bin",
		"minimum-stability": "dev"
	},
	"require": {
		"php": ">=5.0.0",
		"ext-soap": "*",
		"symfony/event-dispatcher": "*@stable",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminKvm\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminKvm\\Tests\\": "tests/"
		}
	}
}
